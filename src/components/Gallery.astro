            Escenografía
          </span>
          <p class="text-sm text-white/70">Ciudad de México · 2026</p>
        </div>
      </div>
      
      <!-- Item 5: Escenario Central -->
      <div class="animate-on-scroll gallery-item group relative rounded-2xl overflow-hidden cursor-pointer aspect-[4/5]">
        <img 
          src={import.meta.env.BASE_URL + "material/gallery/img-05.jpg"} 
          alt="Escena navideña dramática con alto contraste e iluminación teatral" 
