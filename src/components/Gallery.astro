---
---

<section 
  id="proyectos" 
  class="py-16 md:py-20 bg-surface-dark"
  aria-labelledby="proyectos-title"
>
  <div class="max-w-[1200px] mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-16 max-w-[700px] mx-auto">
      <span class="inline-block text-xs font-semibold uppercase tracking-[0.15em] text-primary mb-2 px-3 py-1 bg-primary/20 rounded-full">
        Portafolio
      </span>
      <h2 id="proyectos-title" class="animate-on-scroll text-3xl md:text-4xl font-bold text-white mb-4">
        Nuestros proyectos hablan por nosotros
      </h2>
      <p class="animate-on-scroll text-lg text-white/70 leading-relaxed">
        Cada instalación es una obra de arte diseñada para generar resultados
      </p>
    </div>
    
    <!-- Gallery Grid -->
    <div class="gallery-grid grid grid-cols-2 lg:grid-cols-3 gap-3">
      <!-- Item 1: Drone Aerial Portrait -->
      <div class="animate-on-scroll gallery-item group relative rounded-2xl overflow-hidden cursor-pointer aspect-[4/5]">
        <img 
          src={import.meta.env.BASE_URL + "material/gallery/img-01.jpg"} 
          alt="Vista aérea con dron al atardecer del evento de decoraciones" 
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 will-change-transform"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1200" 
          height="1600"
        >
        <div class="gallery-overlay absolute inset-x-0 bottom-0 p-6 bg-gradient-to-t from-black/90 to-transparent text-white translate-y-full group-hover:translate-y-0 transition-transform duration-400">
          <span class="inline-block text-xs font-semibold uppercase tracking-widest bg-primary text-foreground px-3 py-1 rounded-full mb-2">
            Aérea
          </span>
          <p class="text-sm text-white/70">Ciudad de México · 2026</p>
        </div>
      </div>
      
      <!-- Item 2: Pasillo Dorado -->
      <div class="animate-on-scroll gallery-item group relative rounded-2xl overflow-hidden cursor-pointer aspect-[4/5]">
        <img 
          src={import.meta.env.BASE_URL + "material/gallery/img-02.jpg"} 
          alt="Detalle de decoración cálida con tonos dorados intensos" 
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 will-change-transform"
          loading="lazy"
          fetchpriority="low"
          decoding="async"
          width="800" 
          height="1067"
        >
        <div class="gallery-overlay absolute inset-x-0 bottom-0 p-6 bg-gradient-to-t from-black/90 to-transparent text-white translate-y-full group-hover:translate-y-0 transition-transform duration-400">
          <span class="inline-block text-xs font-semibold uppercase tracking-widest bg-primary text-foreground px-3 py-1 rounded-full mb-2">
            Temporada
          </span>
          <p class="text-sm text-white/70">Ciudad de México · 2026</p>
        </div>
      </div>
      
      <!-- Item 3: Gala de Luces -->
      <div class="animate-on-scroll gallery-item group relative rounded-2xl overflow-hidden cursor-pointer aspect-[4/5]">
        <img 
          src={import.meta.env.BASE_URL + "material/gallery/img-03.jpg"} 
          alt="Detalle de decoración navideña con tonos cálidos y ornamentación" 
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 will-change-transform"
          loading="lazy"
          fetchpriority="low"
          decoding="async"
          width="800" 
          height="1067"
        >
        <div class="gallery-overlay absolute inset-x-0 bottom-0 p-6 bg-gradient-to-t from-black/90 to-transparent text-white translate-y-full group-hover:translate-y-0 transition-transform duration-400">
          <span class="inline-block text-xs font-semibold uppercase tracking-widest bg-primary text-foreground px-3 py-1 rounded-full mb-2">
            Evento
          </span>
          <p class="text-sm text-white/70">Ciudad de México · 2026</p>
        </div>
      </div>
      
      <!-- Item 4: Ambiente Sofisticado -->
      <div class="animate-on-scroll gallery-item group relative rounded-2xl overflow-hidden cursor-pointer aspect-[4/5]">
        <img 
          src={import.meta.env.BASE_URL + "material/gallery/img-04.jpg"} 
          alt="Decoración elegante con iluminación suave y tonos neutros" 
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 will-change-transform"
          loading="lazy"
          fetchpriority="low"
          decoding="async"
          width="800" 
          height="1067"
        >
        <div class="gallery-overlay absolute inset-x-0 bottom-0 p-6 bg-gradient-to-t from-black/90 to-transparent text-white translate-y-full group-hover:translate-y-0 transition-transform duration-400">
