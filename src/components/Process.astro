---
---

<section 
  id="proceso" 
  class="py-16 md:py-20 bg-surface-dark"
  aria-labelledby="proceso-title"
>
  <div class="max-w-[1200px] mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-16 max-w-[700px] mx-auto">
      <span class="inline-block text-xs font-semibold uppercase tracking-[0.15em] text-primary mb-2 px-3 py-1 bg-primary/20 rounded-full">
        Cómo trabajamos
      </span>
      <h2 id="proceso-title" class="animate-on-scroll text-3xl md:text-4xl font-bold text-white mb-4">
        Nuestro proceso de trabajo
      </h2>
      <p class="animate-on-scroll text-lg text-white/70 leading-relaxed">
        Un método probado para garantizar resultados excepcionales
      </p>
    </div>
    
    <!-- Timeline -->
    <ol class="timeline relative max-w-[800px] mx-auto pl-14 list-none">
      <!-- Timeline Line — base gradient (dimmed, sits behind). Position: mobile circles w-12=48px, so line center at 78.5px (pl-14=56 + 24 - 1.5); desktop w-14=56px, so 82.5px. -->
      <div class="timeline-line absolute left-[78.5px] md:left-[82px] top-0 bottom-0 w-[3px] rounded-full bg-gradient-to-b from-primary/30 to-secondary/30" aria-hidden="true"></div>
      <!-- Timeline Progress — solid line filled by scroll position via --progress -->
      <div class="timeline-progress absolute left-[78.5px] md:left-[82px] top-0 w-[3px] rounded-full bg-gradient-to-b from-primary to-secondary" aria-hidden="true" style="height: 0%;"></div>
      
      <!-- Step 1 -->
      <li class="animate-on-scroll timeline-step relative pb-10 md:pb-16 flex gap-6 items-start" aria-labelledby="process-step-1-title">
        <div class="timeline-number number-animate w-12 h-12 md:w-14 md:h-14 rounded-full bg-primary text-foreground font-bold text-lg md:text-xl flex items-center justify-center flex-shrink-0 relative z-[2] shadow-primary border-[3px] border-surface-dark" aria-hidden="true">
          1
        </div>
        <div class="timeline-content pt-1">
          <h3 id="process-step-1-title" class="timeline-title text-xl md:text-[1.35rem] font-semibold text-white mb-1">
            Visita y diagnóstico
          </h3>
          <p class="timeline-desc text-white/75 text-[0.95rem] leading-relaxed">
            Visitamos tu espacio, analizamos el tráfico, la arquitectura y tus objetivos para crear un plan personalizado.
          </p>
        </div>
      </li>
      
      <!-- Step 2 -->
      <li class="animate-on-scroll timeline-step relative pb-10 md:pb-16 flex gap-6 items-start" aria-labelledby="process-step-2-title">
        <div class="timeline-number number-animate w-12 h-12 md:w-14 md:h-14 rounded-full bg-primary text-foreground font-bold text-lg md:text-xl flex items-center justify-center flex-shrink-0 relative z-[2] shadow-primary border-[3px] border-surface-dark" aria-hidden="true">
          2
        </div>
        <div class="timeline-content pt-1">
          <h3 id="process-step-2-title" class="timeline-title text-xl md:text-[1.35rem] font-semibold text-white mb-1">
            Diseño conceptual
          </h3>
          <p class="timeline-desc text-white/75 text-[0.95rem] leading-relaxed">
            Nuestros diseñadores crean propuestas visuales 3D para que veas exactamente cómo quedará tu espacio.
          </p>
        </div>
      </li>
      
      <!-- Checkpoint 1 — Phase break: client approval -->
      <li class="timeline-checkpoint relative pb-10 md:pb-16 flex gap-6 items-start" aria-hidden="true">
        <div class="timeline-checkpoint-marker w-12 h-12 md:w-14 md:h-14 flex-shrink-0 relative z-[2] flex items-center justify-center">
          <div class="w-3 h-3 rounded-full bg-primary shadow-primary"></div>
        </div>
        <div class="timeline-checkpoint-content pt-2 flex items-center gap-2">
          <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
          </svg>
          <span class="text-xs font-semibold uppercase tracking-[0.15em] text-primary">Aprobación del cliente</span>
        </div>
      </li>
      
      <!-- Step 3 -->
      <li class="animate-on-scroll timeline-step relative pb-10 md:pb-16 flex gap-6 items-start" aria-labelledby="process-step-3-title">
        <div class="timeline-number number-animate w-12 h-12 md:w-14 md:h-14 rounded-full bg-primary text-foreground font-bold text-lg md:text-xl flex items-center justify-center flex-shrink-0 relative z-[2] shadow-primary border-[3px] border-surface-dark" aria-hidden="true">
          3
        </div>
        <div class="timeline-content pt-1">
          <h3 id="process-step-3-title" class="timeline-title text-xl md:text-[1.35rem] font-semibold text-white mb-1">
            Fabricación
          </h3>
          <p class="timeline-desc text-white/75 text-[0.95rem] leading-relaxed">
            Construimos cada pieza en nuestro taller con materiales de alta calidad y acabados profesionales.
          </p>
        </div>
      </li>
      
      <!-- Checkpoint 2 — Phase break: logistics -->
      <li class="timeline-checkpoint relative pb-10 md:pb-16 flex gap-6 items-start" aria-hidden="true">
        <div class="timeline-checkpoint-marker w-12 h-12 md:w-14 md:h-14 flex-shrink-0 relative z-[2] flex items-center justify-center">
          <div class="w-3 h-3 rounded-full bg-secondary shadow-secondary"></div>
        </div>
        <div class="timeline-checkpoint-content pt-2 flex items-center gap-2">
          <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <span class="text-xs font-semibold uppercase tracking-[0.15em] text-white/70">Logística y coordinación</span>
        </div>
      </li>
      
      <!-- Step 4 -->
      <li class="animate-on-scroll timeline-step relative pb-10 md:pb-16 flex gap-6 items-start" aria-labelledby="process-step-4-title">
        <div class="timeline-number number-animate w-12 h-12 md:w-14 md:h-14 rounded-full bg-primary text-foreground font-bold text-lg md:text-xl flex items-center justify-center flex-shrink-0 relative z-[2] shadow-primary border-[3px] border-surface-dark" aria-hidden="true">
          4
        </div>
        <div class="timeline-content pt-1">
          <h3 id="process-step-4-title" class="timeline-title text-xl md:text-[1.35rem] font-semibold text-white mb-1">
            Instalación
          </h3>
          <p class="timeline-desc text-white/75 text-[0.95rem] leading-relaxed">
            Nuestro equipo especializado instala todo con precisión, respetando horarios y minimizando impacto.
          </p>
        </div>
      </li>
      
      <!-- Step 5 -->
      <li class="animate-on-scroll timeline-step relative flex gap-6 items-start" aria-labelledby="process-step-5-title">
        <div class="timeline-number number-animate w-12 h-12 md:w-14 md:h-14 rounded-full bg-primary text-foreground font-bold text-lg md:text-xl flex items-center justify-center flex-shrink-0 relative z-[2] shadow-primary border-[3px] border-surface-dark" aria-hidden="true">
          5
        </div>
        <div class="timeline-content pt-1">
          <h3 id="process-step-5-title" class="timeline-title text-xl md:text-[1.35rem] font-semibold text-white mb-1">
            Soporte
          </h3>
          <p class="timeline-desc text-white/75 text-[0.95rem] leading-relaxed">
            Ofrecemos mantenimiento, ajustes y desinstalación cuando lo necesites. Estamos contigo de principio a fin.
          </p>
        </div>
      </li>
    </ol>
  </div>
</section>

<script>
  (function() {
    function initTimelineProgress() {
      var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var progressEls = document.querySelectorAll('.timeline-progress');
      var lineEls = document.querySelectorAll('.timeline-line');
      if (progressEls.length === 0) return;

      // If user prefers reduced motion, show full progress immediately
      if (prefersReducedMotion) {
        progressEls.forEach(function(el) { el.style.height = '100%'; });
        return;
      }

      function updateProgress() {
        progressEls.forEach(function(progressEl, i) {
          var lineEl = lineEls[i];
          if (!lineEl) return;
          var lineRect = lineEl.getBoundingClientRect();
          var viewportH = window.innerHeight;
          // Anchor: line starts being "filled" when its top reaches the middle of the viewport
          // and is fully filled when its bottom passes the middle of the viewport
          var anchor = viewportH * 0.5;
          var lineTop = lineRect.top;
          var lineBottom = lineRect.bottom;
          var lineHeight = lineRect.height;
          if (lineHeight <= 0) return;
          // progress = how much of the line is above the anchor
          var progress = (anchor - lineTop) / lineHeight;
          // clamp 0..1
          if (progress < 0) progress = 0;
          if (progress > 1) progress = 1;
          progressEl.style.height = (progress * 100) + '%';
        });
      }

      // Throttle with requestAnimationFrame
      var ticking = false;
      function onScroll() {
        if (!ticking) {
          window.requestAnimationFrame(function() {
            updateProgress();
            ticking = false;
          });
          ticking = true;
        }
      }

      updateProgress();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTimelineProgress);
    } else {
      initTimelineProgress();
    }
  })();
</script>
