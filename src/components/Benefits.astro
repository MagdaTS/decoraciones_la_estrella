---
---

<section 
  id="beneficios" 
  class="py-16 md:py-20 bg-white"
  aria-labelledby="beneficios-title"
>
  <div class="max-w-[1200px] mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-16 max-w-[700px] mx-auto">
      <span class="inline-block text-xs font-semibold uppercase tracking-[0.15em] text-primary mb-2 px-3 py-1 bg-primary/10 rounded-full">
        Resultados
      </span>
      <h2 id="beneficios-title" class="animate-on-scroll text-3xl md:text-4xl font-bold text-foreground mb-4">
        Impacto real y medible
      </h2>
      <p class="animate-on-scroll text-lg text-muted-foreground leading-relaxed">
        Nuestras instalaciones elevan la experiencia de tus clientes 
      </p>
    </div>
    
    <!-- Benefits Grid -->
    <div class="benefits-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Card 1: Más visitantes -->
      <article class="animate-on-scroll benefit-card group bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-black/5 text-center">
        <div class="benefit-icon w-[72px] h-[72px] rounded-full bg-gradient-to-br from-primary to-primary/20 flex items-center justify-center mx-auto mb-6 text-[1.75rem] text-foreground transition-all duration-300 group-hover:scale-110 group-hover:rotate-[5deg] group-hover:bg-primary">
          <i class="fas fa-users" aria-hidden="true"></i>
        </div>
        <h3 class="text-xl font-semibold text-foreground mb-3">
          Más visitantes
        </h3>
        <p class="text-muted-foreground leading-relaxed">
          Aumenta el tráfico peatonal en tu plaza con instalaciones que atraen y generan curiosidad.
        </p>
      </article>
      
      <!-- Card 2: Más tiempo de permanencia -->
      <article class="animate-on-scroll benefit-card group bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-black/5 text-center">
        <div class="benefit-icon w-[72px] h-[72px] rounded-full bg-gradient-to-br from-primary to-primary/20 flex items-center justify-center mx-auto mb-6 text-[1.75rem] text-foreground transition-all duration-300 group-hover:scale-110 group-hover:rotate-[5deg] group-hover:bg-primary">
          <i class="fas fa-clock" aria-hidden="true"></i>
        </div>
        <h3 class="text-xl font-semibold text-foreground mb-3">
          Más tiempo de permanencia
        </h3>
        <p class="text-muted-foreground leading-relaxed">
          Los visitantes permanecen más tiempo explorando espacios temáticos y atractivos.
        </p>
      </article>
      
      <!-- Card 3: Más fotografías y redes sociales -->
      <article class="animate-on-scroll benefit-card group bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-black/5 text-center">
        <div class="benefit-icon w-[72px] h-[72px] rounded-full bg-gradient-to-br from-primary to-primary/20 flex items-center justify-center mx-auto mb-6 text-[1.75rem] text-foreground transition-all duration-300 group-hover:scale-110 group-hover:rotate-[5deg] group-hover:bg-primary">
          <i class="fas fa-share-nodes" aria-hidden="true"></i>
        </div>
        <h3 class="text-xl font-semibold text-foreground mb-3">
          Más fotografías y redes sociales
        </h3>
        <p class="text-muted-foreground leading-relaxed">
          Escenografías diseñadas para ser compartidas, generando engagement orgánico gratuito.
        </p>
      </article>
      
      <!-- Card 4: Diferenciación -->
      <article class="animate-on-scroll benefit-card group bg-white rounded-2xl p-8 shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-black/5 text-center">
        <div class="benefit-icon w-[72px] h-[72px] rounded-full bg-gradient-to-br from-primary to-primary/20 flex items-center justify-center mx-auto mb-6 text-[1.75rem] text-foreground transition-all duration-300 group-hover:scale-110 group-hover:rotate-[5deg] group-hover:bg-primary">
          <i class="fas fa-gem" aria-hidden="true"></i>
        </div>
        <h3 class="text-xl font-semibold text-foreground mb-3">
          Diferenciación
        </h3>
        <p class="text-muted-foreground leading-relaxed">
          Destaca de la competencia con instalaciones únicas que crean identidad de marca.
        </p>
      </article>
    </div>
  </div>
</section>
