---
import { Image } from 'astro:assets';
import heroBg from '../assets/hero-bg.jpg';
---

<section 
  id="hero" 
  class="min-h-[calc(100dvh-60px)] md:min-h-[calc(100dvh-120px)] relative flex items-center justify-center overflow-hidden"
  aria-label="Sección principal"
>
  <!-- Background Image -->
  <div class="absolute inset-0 z-[1]">
    <Image 
      src={heroBg} 
      alt="Centro comercial decorado espectacularmente con miles de luces doradas" 
      class="w-full h-full object-cover absolute inset-0"
      loading="eager"
      fetchpriority="high"
      width={1920}
      height={1080}
      format="webp"
      quality={80}
    >
    <!-- Overlay -->
    <div 
      class="absolute inset-0 z-[2]"
      style="background: linear-gradient(to bottom, rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0.35));"
    ></div>
  </div>
  
  <!-- Content -->
  <div class="relative z-[3] text-center max-w-[800px] px-6 py-12 text-white">
    <div 
      class="absolute inset-0 -z-10"
      style="background: radial-gradient(ellipse at center, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 50%, transparent 75%);"></div>
    <h1 
      class="hero-fade-in-up text-3xl md:text-5xl font-extrabold text-white mb-6 leading-tight opacity-0"
    >
      Transformamos Espacios en Experiencias Memorables
    </h1>
    
    <p 
      class="hero-fade-in-up hero-delay-1 text-lg md:text-xl font-medium text-white mb-10 max-w-[600px] mx-auto opacity-0"
    >
      Fabricación e instalación de decoraciones temáticas para centros comerciales y espacios públicos.
    </p>
    <div class="hero-fade-in-up hero-delay-2 flex flex-col md:flex-row gap-4 items-center justify-center opacity-0">
      <a
        href="/#contacto"
        class="bg-primary hover:bg-primary-dark text-foreground font-semibold py-4 px-8 rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1"
      >
        Solicitar Propuesta
      </a>
      <a
        href="/#proyectos"
        class="bg-white hover:bg-white/90 text-foreground font-semibold py-4 px-8 rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1"
      >
        Ver Proyectos
      </a>
    </div>
  </div>
  
  <!-- Scroll Indicator -->
  <div class="hero-fade-in-up hero-delay-3 scroll-indicator absolute bottom-12 left-1/2 -translate-x-1/2 z-[3] flex flex-col items-center gap-2 opacity-0">
    <i class="fa-solid fa-chevron-down text-primary text-xl animate-bounce"></i>
  </div>
</section>

<style>
  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .hero-fade-in-up {
    animation: fadeInUp 1s ease forwards;
  }
  
  .hero-fade-in-up.hero-delay-1 {
    animation: fadeInUp 1s ease 0.3s forwards;
  }
  
  .hero-fade-in-up.hero-delay-2 {
    animation: fadeInUp 1s ease 0.6s forwards;
  }
  
  .hero-fade-in-up.hero-delay-3 {
    animation: fadeInUp 1s ease 1s forwards;
  }

</style>
