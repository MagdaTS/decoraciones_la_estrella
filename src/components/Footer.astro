---
const currentYear = new Date().getFullYear();
---

<footer 
  class="bg-surface-footer text-white/75 py-16 md:py-20 pb-8"
  role="contentinfo"
>
  <div class="max-w-[1200px] mx-auto px-6">
    <!-- Footer Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1.5fr] gap-12 lg:gap-10 mb-12">
      <!-- Brand Column -->
      <div class="max-w-[300px]">
        <a href="/#hero" class="inline-block mb-4">
          <img
            src={import.meta.env.BASE_URL + 'Logo-horizontal.png'}
            alt="Decoraciones La Estrella"
            class="h-12 object-contain"
            width="170"
            height="60"
          >
        </a>
        <p class="text-[0.95rem] leading-relaxed mb-4">
          Diseño, fabricación e instalación de decoraciones temáticas para centros comerciales y espacios públicos.
        </p>
        <div class="flex gap-3">
          <a 
            href="https://www.facebook.com/p/Decoraciones-La-Estrella-100095316502754/" 
            target="_blank" 
            rel="noopener noreferrer"
            class="social-link w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center text-white transition-all duration-200 hover:bg-primary hover:text-foreground hover:-translate-y-0.5"
            aria-label="Facebook"
          >
            <i class="fab fa-facebook-f" aria-hidden="true"></i>
          </a>
          <a 
            href="https://www.instagram.com/decoracioneslaestrella_soya/" 
            target="_blank" 
            rel="noopener noreferrer"
            class="social-link w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center text-white transition-all duration-200 hover:bg-primary hover:text-foreground hover:-translate-y-0.5"
            aria-label="Instagram"
          >
            <i class="fab fa-instagram" aria-hidden="true"></i>
          </a>
        </div>
      </div>
      
      <!-- Navigation Column -->
      <div>
        <h4 class="text-base font-bold text-white mb-4 uppercase tracking-wider">
          Navegación
        </h4>
        <ul class="flex flex-col gap-3">
          <li>
            <a href="/#hero" class="text-white/70 transition-all duration-200 hover:text-primary hover:pl-1">
              Inicio
            </a>
          </li>
          <li>
            <a href="/#proyectos" class="text-white/70 transition-all duration-200 hover:text-primary hover:pl-1">
              Proyectos
            </a>
          </li>
          <li>
            <a href="/#catalogos" class="text-white/70 transition-all duration-200 hover:text-primary hover:pl-1">
              Catálogos
            </a>
          </li>
          <li>
            <a href="/#servicios" class="text-white/70 transition-all duration-200 hover:text-primary hover:pl-1">
              Servicios
            </a>
          </li>
          <li>
            <a href="/#proceso" class="text-white/70 transition-all duration-200 hover:text-primary hover:pl-1">
              Proceso
            </a>
          </li>
          <li>
            <a href="/#contacto" class="text-white/70 transition-all duration-200 hover:text-primary hover:pl-1">
              Contacto
            </a>
          </li>
        </ul>
      </div>
      
      <!-- Services Column -->
      <div>
        <h4 class="text-base font-bold text-white mb-4 uppercase tracking-wider">
          Servicios
        </h4>
        <ul class="flex flex-col gap-3">
          <li>
            <a href="/#servicios" class="text-white/70 transition-all duration-200 hover:text-primary hover:pl-1">
              Centros Comerciales
            </a>
          </li>
          <li>
            <a href="/#servicios" class="text-white/70 transition-all duration-200 hover:text-primary hover:pl-1">
              Plazas y Espacios Públicos
            </a>
          </li>
          <li>
            <a href="/#servicios" class="text-white/70 transition-all duration-200 hover:text-primary hover:pl-1">
              Temporadas y Festividades
            </a>
          </li>
          <li>
            <a href="/#servicios" class="text-white/70 transition-all duration-200 hover:text-primary hover:pl-1">
              Servicio Llave en Mano
            </a>
          </li>
        </ul>
      </div>
      
      <!-- Contact Column -->
      <div>
        <h4 class="text-base font-bold text-white mb-4 uppercase tracking-wider">
          Contacto
        </h4>
        <ul class="flex flex-col gap-3 text-[0.95rem]">
          <li class="flex items-center gap-3">
            <i class="fas fa-phone text-primary w-4 text-center" aria-hidden="true"></i>
            +52 563 642 9614
          </li>
          <li class="flex items-center gap-3">
            <i class="fas fa-envelope text-primary w-4 text-center" aria-hidden="true"></i>
            decoracion.laestrella.ventas@gmail.com
          </li>
          <li class="flex items-center gap-3">
            <i class="fab fa-whatsapp text-primary w-4 text-center" aria-hidden="true"></i>
            <a href="https://wa.me/5215636429614" class="text-white/70 hover:text-primary transition-colors duration-200">
              WhatsApp Directo
            </a>
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Footer Bottom -->
    <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row gap-4 items-center justify-between text-center md:text-left">
      <p class="text-sm text-white/50">
        &copy; 2026 Decoraciones La Estrella. Todos los derechos reservados.
      </p>
      <div class="flex gap-6 text-sm">
        <a href="/privacidad" class="text-white/60 hover:text-primary transition-colors duration-200">
          Aviso de Privacidad
        </a>
      </div>
    </div>
  </div>
</footer>
