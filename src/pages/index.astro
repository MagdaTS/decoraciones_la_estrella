---
import Layout from '../layouts/Layout.astro';
import SkipNav from '../components/SkipNav.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Gallery from '../components/Gallery.astro';
import Benefits from '../components/Benefits.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import Process from '../components/Process.astro';
import Cases from '../components/Cases.astro';
import Catalogs from '../components/Catalogs.astro';
import WhyUs from '../components/WhyUs.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import ScrollTop from '../components/ScrollTop.astro';
---

<Layout>
  <SkipNav />
  <Navbar />
  <main id="main-content">
    <Hero />
    <Services />
    <Gallery />
    <Benefits />
    <Process />
    <Cases />
    <Catalogs />
    <Contact />
  </main>
  <Footer />
  <WhatsAppFloat />
  <ScrollTop />
</Layout>
